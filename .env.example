# Oracle DB connection
SANKHYA_DB_HOST=hfsemear.ddns.net
SANKHYA_DB_PORT=1521
SANKHYA_DB_SERVICE=XE
# Alternatively, if your DB uses SID instead of SERVICE_NAME:
# SANKHYA_DB_SID=ORCL
# Or provide a full DSN string (Easy Connect or TNS alias):
# SANKHYA_DB_DSN=hostname:1521/ORCLPDB1
SANKHYA_DB_USER=Sankhya
SANKHYA_DB_PASSWORD=tecsis

# Oracle client thick mode (set to your Instant Client directory)
ORACLE_CLIENT_LIB_DIR=C:\oracle\instantclient_19_23
# Alternatively:
# SANKHYA_ORACLE_CLIENT=C:\oracle\instantclient_19_23
# ORACLE_HOME=C:\oracle\instantclient_19_23

# Feature flags
PACKINGHOUSE_WRITE_ENABLED=true
