# Oracle DB connection
SANKHYA_DB_HOST=hfsemear.ddns.net
SANKHYA_DB_PORT=1521
SANKHYA_DB_SERVICE=XE
# Alternatively, if your DB uses SID instead of SERVICE_NAME:
# SANKHYA_DB_SID=ORCL
# Or provide a full DSN string (Easy Connect or TNS alias):
# SANKHYA_DB_DSN=hostname:1521/ORCLPDB1
SANKHYA_DB_USER=Sankhya
SANKHYA_DB_PASSWORD=tecsis

# Oracle client thick mode (set to your Instant Client directory)
ORACLE_CLIENT_LIB_DIR=C:\oracle\instantclient_19_23
# Alternatively:
# SANKHYA_ORACLE_CLIENT=C:\oracle\instantclient_19_23
# ORACLE_HOME=C:\oracle\instantclient_19_23

# Feature flags
IAGRO_WRITE_ENABLED=true

# ─────────────────────────────────────────────────────────────────────────────
# Importação de pedidos por e-mail (IMAP Titan/Hostinger)
# ─────────────────────────────────────────────────────────────────────────────
# Servidor IMAP do Titan/Hostinger
EMAIL_IMAP_HOST=imap.titan.email
EMAIL_IMAP_PORT=993
EMAIL_IMAP_USER=comercial@agromilagrocomercial.com.br
EMAIL_IMAP_PASS=
# Pastas dentro da caixa do Titan (já criadas no webmail — usar hífen, não barra)
EMAIL_IMAP_FOLDER_ENTRADA=Pedidos-Entrada
EMAIL_IMAP_FOLDER_PROCESSADOS=Pedidos-Processados
EMAIL_IMAP_FOLDER_ERROS=Pedidos-Erros

# ─────────────────────────────────────────────────────────────────────────────
# LLM local (Ollama + Qwen 2.5 14B Instruct)
# ─────────────────────────────────────────────────────────────────────────────
# Endpoint do Ollama. Local (mesma maquina): http://localhost:11434
# Servidor remoto (rede interna):           http://<ip-do-servidor>:11434
OLLAMA_HOST=http://localhost:11434

# Modelo padrao do projeto (rev. Mai/2026 — subido de 7B para 14B porque o
# servidor de producao Xeon E5-2680 v4 com 64GB RAM comporta sem suor).
# Acuracia esperada: 82-90% (vs 75-85% do 7B). Tempo: 40-80s/PDF em CPU.
OLLAMA_MODELO=qwen2.5:14b-instruct

# Timeout maior porque o 14B leva mais tempo que o 7B em CPU
OLLAMA_TIMEOUT_SEGUNDOS=120
OLLAMA_MAX_RETRIES=3

# Experimental — para testar 32B (mais qualidade, ~2-4 min/PDF):
#   1. No servidor: ollama pull qwen2.5:32b-instruct
#   2. Trocar a linha OLLAMA_MODELO acima por:
# OLLAMA_MODELO=qwen2.5:32b-instruct
#   3. Subir OLLAMA_TIMEOUT_SEGUNDOS para 300 enquanto testa

# ─────────────────────────────────────────────────────────────────────────────
# Storage de PDFs originais
# ─────────────────────────────────────────────────────────────────────────────
# Diretório base onde os PDFs são arquivados (subpastas AAAA/MM/ criadas automaticamente)
PEDIDO_EMAIL_PDF_DIR=z:\TI\NexusGTi\IAgro\IAgro\media\pedidos_email
